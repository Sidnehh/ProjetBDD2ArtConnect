<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.GalleryController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <TitledPane text="Search" collapsible="true" expanded="true">
        <HBox spacing="8.0" style="-fx-padding: 10;">
            <TextField fx:id="searchField" promptText="Search galleries..." HBox.hgrow="ALWAYS" />
            <Button text="Search" onAction="#handleSearch" />
            <Button text="Reset" onAction="#handleReset" />
        </HBox>
    </TitledPane>

    <!-- Add New Gallery Section -->
    <TitledPane text="Add New Gallery" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <HBox spacing="10.0">
                <Label text="Name:" prefWidth="100" />
                <TextField fx:id="newGalleryName" promptText="Gallery name" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Street:" prefWidth="100" />
                <TextField fx:id="newGalleryStreet" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="City:" prefWidth="100" />
                <TextField fx:id="newGalleryCity" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Rating:" prefWidth="100" />
                <TextField fx:id="newGalleryRating" promptText="Rating" HBox.hgrow="ALWAYS" />
            </HBox>
            <Button text="Add Gallery" onAction="#handleAddGallery" style="-fx-font-size: 12; -fx-padding: 8; -fx-text-fill: white; -fx-background-color: #4caf50;" />
        </VBox>
    </TitledPane>

    <!-- Update/Delete Section -->
    <TitledPane text="Update or Delete Gallery" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <Label text="Select a gallery from the table below, then modify and click Update or Delete" style="-fx-text-fill: #666;" />
            <HBox spacing="10.0">
                <Label text="Name:" prefWidth="100" />
                <TextField fx:id="editGalleryName" promptText="Name" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Street:" prefWidth="100" />
                <TextField fx:id="editGalleryStreet" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="City:" prefWidth="100" />
                <TextField fx:id="editGalleryCity" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Rating:" prefWidth="100" />
                <TextField fx:id="editGalleryRating" promptText="Rating" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Button text="Update Gallery" onAction="#handleUpdateGallery" style="-fx-font-size: 12; -fx-padding: 8; -fx-text-fill: white; -fx-background-color: #2196f3;" />
                <Button text="Delete Gallery" onAction="#handleDeleteGallery" style="-fx-font-size: 12; -fx-padding: 8; -fx-text-fill: white; -fx-background-color: #f44336;" />
            </HBox>
        </VBox>
    </TitledPane>

    <Label text="Galleries List" style="-fx-font-size: 14; -fx-font-weight: bold;" />
    <TableView fx:id="galleryTable" VBox.vgrow="ALWAYS" onMouseClicked="#handleTableSelection">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="250" />
            <TableColumn fx:id="ratingColumn" text="Rating" prefWidth="100" />
            <TableColumn fx:id="addressColumn" text="Street" prefWidth="250" />
            <TableColumn fx:id="cityColumn" text="City" prefWidth="150" />
        </columns>
    </TableView>
</VBox>
