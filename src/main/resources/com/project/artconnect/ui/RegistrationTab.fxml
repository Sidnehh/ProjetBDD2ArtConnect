<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.RegistrationController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <Label text="Registration Management" style="-fx-font-size: 16; -fx-font-weight: bold;" />

    <GridPane hgap="10.0" vgap="8.0" style="-fx-padding: 10; -fx-background-color: #f8f8f8; -fx-border-color: #dddddd; -fx-border-radius: 4; -fx-background-radius: 4;">
        <columnConstraints>
            <ColumnConstraints prefWidth="140" />
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints prefWidth="140" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Community Member:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <ComboBox fx:id="memberCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="1.7976931348623157E308" />

        <HBox spacing="10.0" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.columnSpan="4" alignment="CENTER_LEFT">
            <Label text="Target Type:" />
            <ComboBox fx:id="targetTypeCombo" prefWidth="180" />
            <Label text="Workshop / Exhibition:" />
            <StackPane HBox.hgrow="ALWAYS">
                <ComboBox fx:id="workshopCombo" maxWidth="1.7976931348623157E308" />
                <ComboBox fx:id="exhibitionCombo" maxWidth="1.7976931348623157E308" visible="false" managed="false" />
            </StackPane>
        </HBox>

        <HBox spacing="10.0" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="4" alignment="CENTER_LEFT">
            <Button text="Register" onAction="#handleRegister" style="-fx-background-color: #4caf50; -fx-text-fill: white;" />
            <Button text="Unregister" onAction="#handleUnregister" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
        </HBox>
    </GridPane>

    <SplitPane dividerPositions="0.58" VBox.vgrow="ALWAYS">
        <VBox spacing="8.0">
            <Label text="Selected Member Enrollments" style="-fx-font-size: 13; -fx-font-weight: bold;" />

            <Label text="Workshops" style="-fx-font-weight: bold;" />
            <TableView fx:id="memberWorkshopsTable" prefHeight="220" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="mwTitle" text="Title" prefWidth="170" />
                    <TableColumn fx:id="mwInstructor" text="Instructor" prefWidth="150" />
                    <TableColumn fx:id="mwDate" text="Date" prefWidth="150" />
                    <TableColumn fx:id="mwPrice" text="Price" prefWidth="90" />
                    <TableColumn fx:id="mwLevel" text="Level" prefWidth="120" />
                </columns>
            </TableView>

            <Label text="Exhibitions" style="-fx-font-weight: bold;" />
            <TableView fx:id="memberExhibitionsTable" prefHeight="220" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="meTitle" text="Title" prefWidth="170" />
                    <TableColumn fx:id="meGallery" text="Gallery" prefWidth="150" />
                    <TableColumn fx:id="meStartDate" text="Start Date" prefWidth="140" />
                    <TableColumn fx:id="meTheme" text="Theme" prefWidth="160" />
                </columns>
            </TableView>
        </VBox>

        <VBox spacing="8.0">
            <Label text="Participants by Selected Workshop/Exhibition" style="-fx-font-size: 13; -fx-font-weight: bold;" />
            <Label fx:id="selectedTargetLabel" text="No target selected" style="-fx-text-fill: #555;" />

            <TableView fx:id="targetMembersTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="tmName" text="Name" prefWidth="170" />
                    <TableColumn fx:id="tmEmail" text="Email" prefWidth="200" />
                    <TableColumn fx:id="tmCity" text="City" prefWidth="140" />
                </columns>
            </TableView>
        </VBox>
    </SplitPane>
</VBox>
