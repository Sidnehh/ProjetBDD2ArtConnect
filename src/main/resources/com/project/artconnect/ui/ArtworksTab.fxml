<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ArtworkController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <!-- Add New Artwork Section -->
    <TitledPane text="Add New Artwork" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <HBox spacing="10.0">
                <Label text="Title:" prefWidth="100" />
                <TextField fx:id="newArtworkTitle" promptText="Artwork title" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Type:" prefWidth="100" />
                <TextField fx:id="newArtworkType" promptText="e.g. Painting, Sculpture" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Price:" prefWidth="100" />
                <TextField fx:id="newArtworkPrice" promptText="Price" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Status:" prefWidth="100" />
                <ComboBox fx:id="newArtworkStatus" prefWidth="200" />
            </HBox>
            <Button text="Add Artwork" onAction="#handleAddArtwork" style="-fx-font-size: 12; -fx-padding: 8;" />
        </VBox>
    </TitledPane>

    <!-- Update/Delete Section -->
    <TitledPane text="Update or Delete Artwork" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <Label text="Select an artwork from the table below, then modify and click Update or Delete" style="-fx-text-fill: #666;" />
            <HBox spacing="10.0">
                <Label text="Title:" prefWidth="100" />
                <TextField fx:id="editArtworkTitle" promptText="Title" HBox.hgrow="ALWAYS" disable="true" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Type:" prefWidth="100" />
                <TextField fx:id="editArtworkType" promptText="Type" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Price:" prefWidth="100" />
                <TextField fx:id="editArtworkPrice" promptText="Price" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Status:" prefWidth="100" />
                <ComboBox fx:id="editArtworkStatus" prefWidth="200" />
            </HBox>
            <HBox spacing="10.0">
                <Button text="Update Artwork" onAction="#handleUpdateArtwork" style="-fx-font-size: 12; -fx-padding: 8; -fx-text-fill: white; -fx-background-color: #2196f3;" />
                <Button text="Delete Artwork" onAction="#handleDeleteArtwork" style="-fx-font-size: 12; -fx-padding: 8; -fx-text-fill: white; -fx-background-color: #f44336;" />
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Artworks Table -->
    <Label text="Artworks List" style="-fx-font-size: 14; -fx-font-weight: bold;" />
    <TableView fx:id="artworkTable" VBox.vgrow="ALWAYS" onMouseClicked="#handleTableSelection">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="200" />
            <TableColumn fx:id="artistColumn" text="Artist" prefWidth="150" />
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="100" />
            <TableColumn fx:id="priceColumn" text="Price" prefWidth="100" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="150" />
        </columns>
    </TableView>
</VBox>
