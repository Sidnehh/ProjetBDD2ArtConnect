<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ArtistController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <!-- Search Section -->
    <TitledPane text="Search" collapsible="true" expanded="true">
        <VBox spacing="5.0" style="-fx-padding: 10;">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search artists..." HBox.hgrow="ALWAYS" />
                <Button text="Search" onAction="#handleSearch" />
                <Button text="Reset" onAction="#handleReset" />
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Add New Artist Section -->
    <TitledPane text="Add New Artist" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <Label text="All fields are required." style="-fx-text-fill: #666;" />
            <HBox spacing="10.0">
                <Label text="Name:" prefWidth="80" />
                <TextField fx:id="newArtistName" promptText="Artist name" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Email:" prefWidth="80" />
                <TextField fx:id="newArtistEmail" promptText="Email" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="City:" prefWidth="80" />
                <TextField fx:id="newArtistCity" promptText="City" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Birth Year:" prefWidth="80" />
                <TextField fx:id="newArtistYear" promptText="Year (e.g. 1980)" HBox.hgrow="ALWAYS" />
            </HBox>
            <Button text="Add Artist" onAction="#handleAddArtist" style="-fx-font-size: 12; -fx-padding: 8;" />
        </VBox>
    </TitledPane>

    <!-- Update/Delete Section -->
    <TitledPane text="Update or Delete Artist" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <Label text="Select an artist from the table below, then modify the fields and click Update or Delete" style="-fx-text-fill: #666;" />
            <HBox spacing="10.0">
                <Label text="Name:" prefWidth="80" />
                <TextField fx:id="editArtistName" promptText="Artist name" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Email:" prefWidth="80" />
                <TextField fx:id="editArtistEmail" promptText="Email" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="City:" prefWidth="80" />
                <TextField fx:id="editArtistCity" promptText="City" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Birth Year:" prefWidth="80" />
                <TextField fx:id="editArtistYear" promptText="Year" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Button text="Update Artist" onAction="#handleUpdateArtist" style="-fx-font-size: 12; -fx-padding: 8;" />
                <Button text="Delete Artist" onAction="#handleDeleteArtist" style="-fx-font-size: 12; -fx-padding: 8; -fx-text-fill: white; -fx-background-color: #f44336;" />
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Artists Table -->
    <Label text="Artists List" style="-fx-font-size: 14; -fx-font-weight: bold;" />
    <TableView fx:id="artistTable" VBox.vgrow="ALWAYS" onMouseClicked="#handleTableSelection">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="200" />
            <TableColumn fx:id="cityColumn" text="City" prefWidth="150" />
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="200" />
            <TableColumn fx:id="yearColumn" text="Birth Year" prefWidth="100" />
        </columns>
    </TableView>
</VBox>
