<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.CommunityController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <TitledPane text="Search" collapsible="true" expanded="true">
        <HBox spacing="8.0" style="-fx-padding: 10;">
            <TextField fx:id="searchField" promptText="Search members..." HBox.hgrow="ALWAYS" />
            <Button text="Search" onAction="#handleSearch" />
            <Button text="Reset" onAction="#handleReset" />
        </HBox>
    </TitledPane>

    <!-- Add New Member Section -->
    <TitledPane text="Add New Community Member" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <HBox spacing="10.0">
                <Label text="Name:" prefWidth="100" />
                <TextField fx:id="newMemberName" promptText="Member name" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Email:" prefWidth="100" />
                <TextField fx:id="newMemberEmail" promptText="Email" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="City:" prefWidth="100" />
                <TextField fx:id="newMemberCity" promptText="City" HBox.hgrow="ALWAYS" />
            </HBox>
            <Button text="Add Member" onAction="#handleAddMember" style="-fx-font-size: 12; -fx-padding: 8;" />
        </VBox>
    </TitledPane>

    <!-- Update/Delete Section -->
    <TitledPane text="Update or Delete Community Member" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <Label text="Select a member from the table below, then modify and click Update or Delete" style="-fx-text-fill: #666;" />
            <HBox spacing="10.0">
                <Label text="Name:" prefWidth="100" />
                <TextField fx:id="editMemberName" promptText="Name" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Email:" prefWidth="100" />
                <TextField fx:id="editMemberEmail" promptText="Email" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="City:" prefWidth="100" />
                <TextField fx:id="editMemberCity" promptText="City" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Button text="Update Member" onAction="#handleUpdateMember" style="-fx-font-size: 12; -fx-padding: 8;" />
                <Button text="Delete Member" onAction="#handleDeleteMember" style="-fx-font-size: 12; -fx-padding: 8; -fx-text-fill: white; -fx-background-color: #f44336;" />
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Members Table -->
    <Label text="Community Members List" style="-fx-font-size: 14; -fx-font-weight: bold;" />
    <TableView fx:id="memberTable" VBox.vgrow="ALWAYS" onMouseClicked="#handleTableSelection">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="250" />
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="250" />
            <TableColumn fx:id="cityColumn" text="City" prefWidth="150" />
        </columns>
    </TableView>

    <!-- Registration Section -->
    <Separator />
    <Label text="Registrations" style="-fx-font-size: 14; -fx-font-weight: bold;" />

    <TitledPane text="Register to Workshops" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <Label text="Select a member first, then choose a workshop to register" style="-fx-text-fill: #666;" />
            <Label text="Available Workshops:" style="-fx-font-weight: bold;" />
            <TableView fx:id="availableWorkshopsTable" prefHeight="150" VBox.vgrow="ALWAYS" onMouseClicked="#handleWorkshopSelection">
                <columns>
                    <TableColumn fx:id="wsTitle" text="Title" prefWidth="200" />
                    <TableColumn fx:id="wsInstructor" text="Instructor" prefWidth="150" />
                    <TableColumn fx:id="wsDate" text="Date" prefWidth="150" />
                    <TableColumn fx:id="wsPrice" text="Price" prefWidth="80" />
                </columns>
            </TableView>
            <Button text="Register to Selected Workshop" onAction="#handleRegisterWorkshop" style="-fx-font-size: 12; -fx-padding: 8; -fx-background-color: #4caf50; -fx-text-fill: white;" />
        </VBox>
    </TitledPane>

    <TitledPane text="Register to Exhibitions" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <Label text="Select a member first, then choose an exhibition to register" style="-fx-text-fill: #666;" />
            <Label text="Available Exhibitions:" style="-fx-font-weight: bold;" />
            <TableView fx:id="availableExhibitionsTable" prefHeight="150" VBox.vgrow="ALWAYS" onMouseClicked="#handleExhibitionSelection">
                <columns>
                    <TableColumn fx:id="exTitle" text="Title" prefWidth="200" />
                    <TableColumn fx:id="exTheme" text="Theme" prefWidth="150" />
                    <TableColumn fx:id="exDate" text="Start Date" prefWidth="150" />
                </columns>
            </TableView>
            <Button text="Register to Selected Exhibition" onAction="#handleRegisterExhibition" style="-fx-font-size: 12; -fx-padding: 8; -fx-background-color: #4caf50; -fx-text-fill: white;" />
        </VBox>
    </TitledPane>

    <TitledPane text="My Registrations" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                <Tab text="Workshops" closable="false">
                    <VBox spacing="8.0" style="-fx-padding: 10;">
                        <TableView fx:id="myWorkshopsTable" prefHeight="150" VBox.vgrow="ALWAYS" onMouseClicked="#handleMyWorkshopSelection">
                            <columns>
                                <TableColumn fx:id="myWsTitle" text="Title" prefWidth="250" />
                                <TableColumn fx:id="myWsDate" text="Date" prefWidth="200" />
                            </columns>
                        </TableView>
                        <Button text="Unregister from Selected Workshop" onAction="#handleUnregisterWorkshop" style="-fx-font-size: 12; -fx-padding: 8; -fx-background-color: #f44336; -fx-text-fill: white;" />
                    </VBox>
                </Tab>
                <Tab text="Exhibitions" closable="false">
                    <VBox spacing="8.0" style="-fx-padding: 10;">
                        <TableView fx:id="myExhibitionsTable" prefHeight="150" VBox.vgrow="ALWAYS" onMouseClicked="#handleMyExhibitionSelection">
                            <columns>
                                <TableColumn fx:id="myExTitle" text="Title" prefWidth="250" />
                                <TableColumn fx:id="myExDate" text="Date" prefWidth="200" />
                            </columns>
                        </TableView>
                        <Button text="Unregister from Selected Exhibition" onAction="#handleUnregisterExhibition" style="-fx-font-size: 12; -fx-padding: 8; -fx-background-color: #f44336; -fx-text-fill: white;" />
                    </VBox>
                </Tab>
            </TabPane>
        </VBox>
    </TitledPane>
</VBox>
