<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ExhibitionController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <!-- Add New Exhibition Section -->
    <TitledPane text="Add New Exhibition" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <HBox spacing="10.0">
                <Label text="Title:" prefWidth="100" />
                <TextField fx:id="newExhibitionTitle" promptText="Exhibition title" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Start Date:" prefWidth="100" />
                <DatePicker fx:id="newExhibitionStartDate" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Theme:" prefWidth="100" />
                <TextField fx:id="newExhibitionTheme" promptText="Exhibition theme" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Gallery:" prefWidth="100" />
                <ComboBox fx:id="newExhibitionGallery" prefWidth="200" HBox.hgrow="ALWAYS" />
            </HBox>
            <Button text="Add Exhibition" onAction="#handleAddExhibition" style="-fx-font-size: 12; -fx-padding: 8;" />
        </VBox>
    </TitledPane>

    <!-- Update/Delete Section -->
    <TitledPane text="Update or Delete Exhibition" collapsible="true" expanded="false">
        <VBox spacing="8.0" style="-fx-padding: 10;">
            <Label text="Select an exhibition from the table below, then modify and click Update or Delete" style="-fx-text-fill: #666;" />
            <HBox spacing="10.0">
                <Label text="Title:" prefWidth="100" />
                <TextField fx:id="editExhibitionTitle" promptText="Title" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Start Date:" prefWidth="100" />
                <DatePicker fx:id="editExhibitionStartDate" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Label text="Theme:" prefWidth="100" />
                <TextField fx:id="editExhibitionTheme" promptText="Theme" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10.0">
                <Button text="Update Exhibition" onAction="#handleUpdateExhibition" style="-fx-font-size: 12; -fx-padding: 8; -fx-text-fill: white; -fx-background-color: #2196f3;" />
                <Button text="Delete Exhibition" onAction="#handleDeleteExhibition" style="-fx-font-size: 12; -fx-padding: 8; -fx-text-fill: white; -fx-background-color: #f44336;" />
            </HBox>
        </VBox>
    </TitledPane>

    <!-- Exhibitions Table -->
    <Label text="Exhibitions List" style="-fx-font-size: 14; -fx-font-weight: bold;" />
    <TableView fx:id="exhibitionTable" VBox.vgrow="ALWAYS" onMouseClicked="#handleTableSelection">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="200" />
            <TableColumn fx:id="galleryColumn" text="Gallery" prefWidth="150" />
            <TableColumn fx:id="dateColumn" text="Start Date" prefWidth="120" />
            <TableColumn fx:id="themeColumn" text="Theme" prefWidth="180" />
        </columns>
    </TableView>
</VBox>
